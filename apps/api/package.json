{
  "name": "@medgram/api",
  "version": "0.1.0",
  "private": true,
  "description": "Backend NestJS: API REST de contenido, aprobación y jobs de publicación",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main.js",
    "test": "nest build && node --test test/*.test.mjs",
    "test:e2e": "node test/e2e.mjs",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:seed": "prisma db seed",
    "db:seed:demo": "tsx prisma/seed-demo.ts",
    "db:studio": "prisma studio"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@medgram/content-pipeline": "*",
    "@medgram/shared-types": "*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/client": "^6.0.0",
    "bullmq": "^5.80.8",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "googleapis": "^173.0.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "twilio": "^6.0.2"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "prisma": "^6.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
