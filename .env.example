# --- Base de datos (valores por defecto de docker-compose.yml) ---
# Puerto 5434: el 5432 lo ocupa PostgreSQL nativo y el 5433 un relay de WSL en esta máquina
DATABASE_URL=postgresql://medgram:medgram@localhost:5434/medgram

# --- Redis (BullMQ, publicación programada) ---
REDIS_URL=redis://localhost:6379

# --- API NestJS ---
API_PORT=3001

# --- Dashboard Next.js ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Claude API (generación de copy) ---
# Sin API key, el pipeline usa un stub de plantilla conforme (Fase 1 demostrable sin key).
ANTHROPIC_API_KEY=
# Modelo opcional; por defecto claude-opus-4-8.
ANTHROPIC_MODEL=

# --- Notificaciones al doctor ---
# Si SMTP_HOST queda vacío, las notificaciones solo se loguean en consola.
NOTIFY_DOCTOR_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=medgram <no-reply@medgram.local>
# Base para los enlaces del email al detalle del contenido.
DASHBOARD_URL=http://localhost:3000
