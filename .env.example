# --- Base de datos (valores por defecto de docker-compose.yml) ---
# Puerto 5434: el 5432 lo ocupa PostgreSQL nativo y el 5433 un relay de WSL en esta máquina
DATABASE_URL=postgresql://medgram:medgram@localhost:5434/medgram

# --- Redis (BullMQ, publicación programada) ---
REDIS_URL=redis://localhost:6379

# --- API NestJS ---
API_PORT=3001

# --- Dashboard Next.js ---
NEXT_PUBLIC_API_URL=http://localhost:3001

# --- Claude API (generación de copy) ---
# Sin API key, el pipeline usa un stub de plantilla conforme (Fase 1 demostrable sin key).
ANTHROPIC_API_KEY=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"
# Modelo opcional; por defecto claude-opus-4-8.
ANTHROPIC_MODEL=

# --- Notificaciones al doctor ---
# Si SMTP_HOST queda vacío, las notificaciones solo se loguean en consola.
NOTIFY_DOCTOR_EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=medgram <no-reply@medgram.local>
# Base para los enlaces del email al detalle del contenido.
DASHBOARD_URL=http://localhost:3000

# --- WhatsApp Booking (Twilio) ---
# Si no se configuran, el servicio simula los envíos en consola (útil en desarrollo).
# Obtener credenciales en https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
# Número de Twilio con WhatsApp Business habilitado (formato whatsapp:+1XXXXXXXXXX)
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Número de WhatsApp del consultorio que se muestra en los mensajes de agendación.
DOCTOR_WHATSAPP_NUMBER=

# --- HuggingFace (generación de imágenes) ---
# Sin token se usa Pollinations.ai como fallback gratuito.
HUGGINGFACE_API_TOKEN=

# --- Scheduler ---
# Cron para generación diaria. Por defecto: 10:00 UTC = 07:00 Chile.
DAILY_CRON=0 10 * * *

# --- Instagram Publishing (Fase 2 — requiere Meta App Review aprobado) ---
# Obtener en Meta for Developers → Tu App → Instagram Basic Display
# Sin credenciales, el sistema usa el publicador stub (simula publicación).
INSTAGRAM_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# --- Google Calendar (agendación de citas) ---
# Service Account: crear en Google Cloud Console → IAM → Service Accounts
# Compartir el calendario con el email del Service Account (rol Editor)
# Sin credenciales, el servicio corre en modo simulación (todos los slots disponibles).
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
# ID del calendario (email del calendario o "primary")
GOOGLE_CALENDAR_ID=primary

# --- Meta Ads (Fase 3 — publicidad en Instagram/Facebook) ---
# Obtener en Meta for Developers → Tu App → Marketing API
# Sin credenciales, el módulo de ads corre en modo simulación.
META_AD_ACCOUNT_ID=
META_FACEBOOK_PAGE_ID=
